  <style>
    body {
      font-family: Arial;
      margin: 0;
      background: #ffe5e5;
    }

    header {
      background: red;
      color: white;
      padding: 20px;
      text-align: center;
    }

    section {
      padding: 20px;
    }

    .card {
      background: white;
