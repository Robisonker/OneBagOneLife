    <div class="card">A+</div>
    <div class="card">B+</div>
    <div class="card">O+</div>
    <div class="card">AB+</div>
    <div class="card">A-</div>
    <div class="card">B-</div>
    <div class="card">O-</div>
    <div class="card">AB-</div>
  </section>

  <section>
    <h2>Become Donor</h2>

    <input type="text" placeholder="Your Name"><br><br>

    <input type="text" placeholder="Phone Number"><br><br>

    <button>Submit</button>
